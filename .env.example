# Convex backend URL (used by the frontend at build time)
VITE_CONVEX_URL=https://kindhearted-lark-661.convex.cloud

# Optional: canonical site origin for copied iframe embed code (defaults to current origin in dev)
# VITE_PUBLIC_SITE_URL=https://www.thesynlab.com

# Google Tag Manager container ID (GTM-XXXX). When set, only GTM loads (add Ahrefs Custom HTML + GA4 there).
# When unset, the app loads Ahrefs + direct GA4 below (no GTM).
# VITE_GTM_CONTAINER_ID=GTM-XXXXXXX

# GA4 Measurement ID — https://thesynlab.com/ property (ID: 531573397)
# Injected into index.html at build time via the injectGa4Plugin in vite.config.ts.
# In Coolify: add VITE_GA4_MEASUREMENT_ID as a Build Argument with this value.
VITE_GA4_MEASUREMENT_ID=G-XMGRJBSN5Y

# --- Passive revenue (optional build-time) ---
# Amazon Associates store ID / tag (appends ?tag= on amazon.* outbound product links).
# VITE_AMAZON_ASSOCIATES_TAG=yourstore-20

# Google AdSense: publisher client ca-pub-xxx and per-ad-unit slot IDs (matches AdSlot slotName keys).
# VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# VITE_ADSENSE_SLOT_REVIEW_SIDEBAR=1234567890
# VITE_ADSENSE_SLOT_HOME_LEADERBOARD=1234567890
# VITE_ADSENSE_SLOT_COMPARE_INLINE=1234567890
# VITE_ADSENSE_SLOT_COMPARE_SIDEBAR=1234567890
# When Convex adSlotConfigs are empty, set to 1 to still render AdSense from env only.
# VITE_ADSENSE_FALLBACK_WITHOUT_DB=1

# Convex deployment key - for CLI only (npx convex dev / npx convex deploy).
# Get from: https://dashboard.convex.dev → your deployment → Settings
CONVEX_DEPLOY_KEY=dev:kindhearted-lark-661|eyJ2MiI6IjYwODUwYWVjMGMwOTQ2YTU4ZTVmMWZhZjYxZDc3ZmVhIn0=

# =============================================================================
# FREE TIER – No API keys required. Works out of the box at $0/month.
# =============================================================================

# --- ML Predictions (S1) ---
# FREE: Uses built-in heuristic when unset. No key needed.
# PAID: Optional ML_API_URL for external XGBoost/FastAPI service.
# ML_API_URL=

# --- Blockchain (S3) ---
# FREE: Simulated deterministic verification when unset. No key needed.
# PAID: Alchemy free tier (30M CUs/month) – sign up at alchemy.com
# ALCHEMY_API_KEY=
# ALCHEMY_API_URL=https://polygon-mainnet.g.alchemy.com/v2
# ALCHEMY_FROM_ADDRESS=

# --- Translation (S9) ---
# FREE: MyMemory API (no key). Optional MYMEMORY_EMAIL for higher daily limit.
# PAID: ANTHROPIC_API_KEY for Claude (higher quality, paid).
# MYMEMORY_EMAIL=
# ANTHROPIC_API_KEY=

# --- Affiliate Prices (S10) ---
# FREE: Uses product base price + variance when unset. No key needed.
# PAID: AFFILIATE_PRICE_API_URL for live price fetches.
# AFFILIATE_PRICE_API_URL=
