# Convex backend URL (used by the frontend at build time)
VITE_CONVEX_URL=https://kindhearted-lark-661.convex.cloud

# Convex deployment key - for CLI only (npx convex dev / npx convex deploy).
# Set in Coolify Build → Environment Variables when using automated Convex deploys.
# Get from: https://dashboard.convex.dev → your deployment → Settings
CONVEX_DEPLOY_KEY=
